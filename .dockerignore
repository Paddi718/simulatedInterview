data/
*.db
*.log

# Python 虚拟环境
venv/
.venv/
__pycache__/
*.pyc

# Node
node_modules/
.next/

# 模型（大文件）
models/
*.pt
*.pth

# 文档截图等
docs/
*.md

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml
Dockerfile*
.dockerignore

# 脚本（不需要在镜像里）
run_*.sh
