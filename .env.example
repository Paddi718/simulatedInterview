# ============================
# Database (PostgreSQL)
# ============================
POSTGRES_USER=interview_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=interview_db
# Docker 内部使用 postgres 主机名（容器名），本地开发改为 localhost
DATABASE_URL=postgresql+asyncpg://interview_user:change_this_password@postgres:5432/interview_db

# ============================
# Redis
# ============================
# Docker 内部使用 redis 主机名（容器名），本地开发改为 localhost
REDIS_URL=redis://redis:6379/0

# ============================
# JWT 认证
# ============================
# 生产环境务必改为随机强密码（如: openssl rand -hex 32）
JWT_SECRET=change_this_jwt_secret

# ============================
# 语音识别 — FunASR 本地模型（免费）
# ============================
# 模型目录（Docker 时通常挂载到 /app/models）
ASR_MODEL_DIR=models/SenseVoiceSmall

# ============================
# 语音合成 — Edge TTS（微软免费 TTS）
# ============================
# 无需配置，使用微软 Edge 免费服务

# ============================
# LLM API（必填）
# ============================
LLM_API_KEY=your_llm_api_key
LLM_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ============================
# 前端环境变量（Next.js 构建时使用）
# ============================
# Docker 部署使用实际服务器地址或 nginx 反向代理地址
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ============================
# 文件存储路径
# ============================
# Docker 部署时映射到 /var/data/interview-app/ 下
AUDIO_STORAGE_PATH=/var/data/interview-app/audio
DOCUMENT_STORAGE_PATH=/var/data/interview-app/documents
RESUME_STORAGE_PATH=/var/data/interview-app/resumes
